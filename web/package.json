{
  "name": "reearth-marketplace",
  "description": "Re:Earth marketplace for publishing and sharing plugins",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.14.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "build:ext": "tsc && vite build -c vite.config.ext.ts && node ./TEMP",
    "preview": "vite preview",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "eslint . --fix",
    "type": "tsc",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "gql": "graphql-codegen --config codegen.yml",
    "i18n": "i18next"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/fragment-matcher": "6.0.0",
    "@graphql-codegen/introspection": "5.0.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@graphql-codegen/typescript-operations": "5.0.9",
    "@graphql-codegen/typescript-react-apollo": "4.4.1",
    "@rollup/plugin-yaml": "4.1.2",
    "@storybook/addon-actions": "9.0.8",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-links": "10.3.3",
    "@storybook/builder-vite": "10.3.3",
    "@storybook/react": "10.3.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-hooks": "8.0.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "babel-loader": "10.1.1",
    "babel-plugin-macros": "3.1.0",
    "eslint": "10.1.0",
    "eslint-config-reearth": "0.3.8",
    "eslint-plugin-graphql": "4.0.0",
    "eslint-plugin-import": "^2.32.0",
    "i18next-parser": "9.4.0",
    "jsdom": "29.0.1",
    "msw": "2.12.14",
    "prettier": "3.8.1",
    "rollup-plugin-external-globals": "0.13.0",
    "rollup-plugin-visualizer": "7.0.1",
    "storybook-react-i18next": "10.1.1",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-css-injected-by-js": "4.0.1",
    "vitest": "4.1.2"
  },
  "dependencies": {
    "@ant-design/compatible": "5.1.4",
    "@ant-design/cssinjs": "2.1.2",
    "@ant-design/icons": "6.1.1",
    "@ant-design/pro-layout": "7.22.7",
    "@ant-design/pro-table": "3.21.0",
    "@apollo/client": "4.1.6",
    "@auth0/auth0-react": "2.16.0",
    "@emotion/css": "11.13.5",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@types/apollo-upload-client": "19.0.0",
    "antd": "6.3.4",
    "apollo-upload-client": "19.0.0",
    "dayjs": "1.11.20",
    "graphiql": "5.2.2",
    "graphql": "16.13.2",
    "i18next": "26.0.1",
    "i18next-browser-languagedetector": "8.2.1",
    "jotai": "2.19.0",
    "react": "19.2.4",
    "react-accessible-accordion": "5.0.1",
    "react-dom": "19.2.4",
    "react-i18next": "17.0.1",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.13.2",
    "remark-gfm": "4.0.1",
    "tinycolor2": "1.6.0"
  },
  "msw": {
    "workerDirectory": "src/test/mocks"
  }
}
